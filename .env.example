# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gpcet_campusiq

# JWT
JWT_ACCESS_SECRET=gpcet_campusiq_access_secret_minimum_32_chars_here
JWT_REFRESH_SECRET=gpcet_campusiq_refresh_secret_minimum_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Groq AI — FREE key at console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Cloudinary — FREE at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
